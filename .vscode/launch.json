{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run PDF Split App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "redirectOutput": true,
            "logToFile": true,
            "subProcess": true,
            "justMyCode": true
        },
        {
            "name": "Run PDF Split App (All Code)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "redirectOutput": true,
            "logToFile": true,
            "subProcess": true,
            "justMyCode": false
        },
        {
            "name": "Attach (debugpy :5678)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "127.0.0.1",
                "port": 5678
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        }
    ]
}
